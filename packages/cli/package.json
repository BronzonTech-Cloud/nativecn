{
  "name": "@nativecn/cli",
  "version": "0.3.7",
  "private": false,
  "description": "CLI tool for initializing and managing NativeCN components in React Native projects",
  "author": "major tom <tailwiinder@gmail.com>",
  "license": "MIT",
  "homepage": "https://www.nativecn.xyz/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tailwiinder/nativecn.git"
  },
  "keywords": [
    "react-native",
    "nativecn",
    "ui-components",
    "cli"
  ],
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "nativecn": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "clsx": "^2.1.1",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "fs-extra": "^11.3.0",
    "nativewind": "^4.2.2",
    "prompts": "^2.4.2",
    "react": "^19.0.0",
    "react-native": "^0.84.1",
    "react-native-vector-icons": "^10.3.0",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/fs-extra": "^11.0.0",
    "@types/jest": "^30.0.0",
    "@types/prompts": "^2.4.2",
    "@types/react": "^19.2.14",
    "jest": "^30.2.0",
    "react-test-renderer": "^19.2.4",
    "typescript": "^5.8.2"
  }
}
